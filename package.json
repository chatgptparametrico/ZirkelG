{
  "name": "zirkelg",
  "version": "2.0.3",
  "description": "Zirkel G Standalone Gallery",
  "author": "ZirkelG Team",
  "main": "main.js",
  "scripts": {
    "serve": "npx -y http-server . -p 8080 -o",
    "start": "node server.js",
    "electron-dev": "electron .",
    "dist": "electron-builder --win portable"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.1",
    "archiver": "^7.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "multer": "^2.1.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "puppeteer": "^24.38.0"
  },
  "build": {
    "appId": "com.zirkelg.app",
    "productName": "ZirkelG",
    "win": {
      "target": "portable",
      "icon": "zirkel-logo.png"
    },
    "portable": {
      "artifactName": "${productName}_Portable.${ext}",
      "unpackDirName": "zirkelg-temp"
    },
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "electronDownload": {
      "cache": "C:/Users/admin/eb_cache/electron-cache"
    }
  }
}
